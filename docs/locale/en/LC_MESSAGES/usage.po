#: ../../usage/intro.rst:5
msgid "概要"
msgstr "Overview"

#: ../../usage/intro.rst:7
msgid ""
"AOFDFTはPythonモジュール\\ `ASE(Atomic Simulation Environment) <https://ase-"
"lib.org/>`_\\ "
"のCalculatorとして実装されています。このマニュアルではASE自体の説明には深入りせず、AOFDFT独自の使用方法を中心に説明します。"
msgstr ""
"AOFDFT is implemented as a Calculator for the Python module `ASE (Atomic "
"Simulation Environment) <https://ase-lib.org/>`_. This manual focuses on "
"usage specific to AOFDFT, without going into detail about ASE itself."

#: ../../usage/intro.rst:9
msgid "ASE自体の使い方については公式のドキュメントやウェブ上の解説をご参照ください。"
msgstr ""
"Please refer to the official documentation or explanations on the web for"
" how to use ASE itself."

#: ../../usage/intro.rst:14
msgid "使用例"
msgstr "Usage example"

#: ../../usage/intro.rst:16
#, python-brace-format
msgid ""
"# Calculatorをインポート\n"
"from aofdft.calculator import AOFDFTCalculator\n"
"from ase.build import bulk\n"
"from ase.io import read\n"
"\n"
"# Atomsオブジェクトを作成\n"
"atoms = bulk(\"Si\", crystalstructure=\"diamond\", a=5.43)\n"
"# ファイルから読み込む場合\n"
"#atoms = read(\"si.cif\")\n"
"\n"
"# Calculatorオブジェクトを設定\n"
"atoms.calc = AOFDFTCalculator(kin_type=\"AS25\", "
"kin_model=\"AdvanceSoft25-80Ry-ft\", xc=\"LDA\")\n"
"\n"
"# Atomsオブジェクトのメソッドを呼び出すと計算が行われる\n"
"energy = atoms.get_potential_energy()\n"
"forces = atoms.get_forces()\n"
"\n"
"# 出力\n"
"print(f\"\\nTotal energy: {energy:.6f} eV\")\n"
"print(\"Forces on atoms (eV/Å):\")\n"
"print(forces)"
msgstr ""
"# Import the Calculator\n"
"from aofdft.calculator import AOFDFTCalculator\n"
"from ase.build import bulk\n"
"from ase.io import read\n"
"\n"
"# Create an Atoms object\n"
"atoms = bulk(\"Si\", crystalstructure=\"diamond\", a=5.43)\n"
"# If reading from a file\n"
"#atoms = read(\"si.cif\")\n"
"\n"
"# Set the Calculator object\n"
"atoms.calc = AOFDFTCalculator(kin_type=\"AS25\", "
"kin_model=\"AdvanceSoft25-80Ry-ft\", xc=\"LDA\")\n"
"\n"
"# Calculation is performed when calling the Atoms object methods\n"
"energy = atoms.get_potential_energy()\n"
"forces = atoms.get_forces()\n"
"\n"
"# Output\n"
"print(f\"\\nTotal energy: {energy:.6f} eV\")\n"
"print(\"Forces on atoms (eV/Å):\")\n"
"print(forces)"

