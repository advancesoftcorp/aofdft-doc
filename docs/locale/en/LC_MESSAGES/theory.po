msgstr "Pair of coordinates :math:`(\\mathbf{r}, \\mathbf{r}')`"

#: ../../theory.rst:89
#, python-brace-format
msgid "特徴ベクトル :math:`\\mathbf{h}_i`"
msgstr "Feature vector :math:`\\mathbf{h}_i`"

#: ../../theory.rst:89
#, python-brace-format
